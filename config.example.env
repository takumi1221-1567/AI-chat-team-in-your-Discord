# Copy to ".env" (which is git-ignored) and fill in.
# Only DISCORD_BOT_TOKEN is required for a fully-local team.

DISCORD_BOT_TOKEN=your-discord-bot-token

# Optional
DISCORD_CHANNEL_ID=0                      # 0 = listen on all channels
OLLAMA_HOST=http://localhost:11434        # local Ollama endpoint
AGENTS_FILE=agents.yaml                   # team definition (defaults to agents.yaml)

# Secrets referenced by http agents via ${VAR} in agents.yaml headers, e.g.:
# X_AGENT_TOKEN=...
